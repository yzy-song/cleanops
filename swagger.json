  "info": {
    "title": "CleanOps API",
    "description": "The CleanOps 2026 Management API - 专业清洁业务管理系统",
    "version": "1.0",
    "contact": {}
  },
  "tags": [],
  "servers": [
    {
      "url": "http://localhost:3000",
      "description": "Local development"
    }
  ],
  "components": {
    "securitySchemes": {
      "bearer": {
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "type": "http"
      }
    },
    "schemas": {
      "CreateCompanyWithAdminDto": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "example": "Joy Cleaning Ltd",
            "description": "公司名称"
          },
          "vatNumber": {
            "type": "string",
            "example": "IE1234567W",
            "description": "爱尔兰 VAT 税号"
          },
          "baseHourlyRate": {
            "type": "number",
            "example": 1550,
            "default": 1480,
            "description": "起薪(分)，1550=15.50欧"
          },
          "adminEmail": {
            "type": "string",
            "example": "admin@company.com",
            "description": "管理员邮箱"
          },
          "adminPass": {
            "type": "string",
            "example": "securePassword123",
            "description": "管理员密码"
          }
        },
        "required": [
          "name",
          "baseHourlyRate",
          "adminEmail",
          "adminPass"
        ]
      },
      "UpdateCompanyDto": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "example": "Joy Cleaning Ltd",
            "description": "公司名称"
          },
          "vatNumber": {
            "type": "string",
            "example": "IE1234567W",
            "description": "爱尔兰 VAT 税号"
          },
          "baseHourlyRate": {
            "type": "number",
            "example": 1550,
            "default": 1480,
            "description": "起薪(分)，1550=15.50欧"
          }
        }
      },
      "CreateWorkerDto": {
        "type": "object",
        "properties": {
          "firstName": {
            "type": "string",
            "example": "Liam"
          },
          "lastName": {
            "type": "string",
            "example": "Murphy"
          },
          "phone": {
            "type": "string",
            "example": "0851234567",
            "description": "电话号码"
          },
          "email": {
            "type": "string",
            "example": "liam.murphy@example.com",
            "description": "邮箱地址"
          },
          "ppsn": {
            "type": "string",
            "example": "1234567FA",
            "description": "PPSN 号码"
          },
          "hourlyRate": {
            "type": "number",
            "example": 1600,
            "description": "时薪(分)"
          },
          "companyId": {
            "type": "string",
            "example": "company-uuid-here"
          }
        },
        "required": [
          "firstName",
          "lastName",
          "phone",
          "email",
          "companyId"
        ]
      },
      "UpdateWorkerDto": {
        "type": "object",
        "properties": {
          "firstName": {
            "type": "string",
            "example": "Liam"
          },
          "lastName": {
            "type": "string",
            "example": "Murphy"
          },
          "phone": {
            "type": "string",
            "example": "0851234567",
            "description": "电话号码"
          },
          "email": {
            "type": "string",
            "example": "liam.murphy@example.com",
            "description": "邮箱地址"
          },
          "ppsn": {
            "type": "string",
            "example": "1234567FA",
            "description": "PPSN 号码"
          },
          "hourlyRate": {
            "type": "number",
            "example": 1600,
            "description": "时薪(分)"
          },
          "companyId": {
            "type": "string",
            "example": "company-uuid-here"
          }
        }
      },
      "CreateCustomerDto": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "example": "Alice Johnson"
          },
          "address": {
            "type": "string",
            "example": "123 Dublin St, Dublin 2",
            "description": "完整地址"
          },
          "eircode": {
            "type": "string",
            "example": "D02 X123",
            "description": "爱尔兰 Eircode"
          },
          "accessCode": {
            "type": "string",
            "example": "Key under the mat / Code: 1234",
            "description": "入户方式"
          },
          "lat": {
            "type": "number",
            "example": 53.3498
          },
          "lng": {
            "type": "number",
            "example": -6.2603
          },
          "companyId": {
            "type": "string",
            "example": "uuid-of-company"
          },
          "isCommercial": {
            "type": "boolean",
            "example": true,
            "description": "商业/住宅"
          }
        },
        "required": [
          "name",
          "address",
          "eircode",
          "accessCode",
          "lat",
          "lng"
        ]
      },
