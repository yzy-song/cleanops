            "type": "string",
            "example": "2026-05-01T09:00:00Z"
          },
          "estimatedDuration": {
            "type": "number",
            "example": 120,
            "description": "预计耗时（分钟）"
          },
          "customerId": {
            "type": "string",
            "example": "customer-uuid"
          },
          "workerIds": {
            "example": [
              "worker-uuid-1"
            ],
            "description": "指派的员工ID列表",
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "notes": {
            "type": "string",
            "example": "请带上备用钥匙"
          }
        },
        "required": [
          "scheduledStart",
          "customerId"
        ]
      },
      "UpdateJobDto": {
        "type": "object",
        "properties": {
          "scheduledStart": {
            "type": "string",
            "example": "2026-05-01T09:00:00Z"
          },
          "estimatedDuration": {
            "type": "number",
