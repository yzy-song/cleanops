          },
          "customerId": {
            "type": "string",
            "example": "customer-uuid"
          },
          "workerIds": {
            "example": [
              "worker-uuid-1"
            ],
            "description": "指派的员工ID列表",
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "notes": {
            "type": "string",
            "example": "请带上备用钥匙"
          }
        }
      },
      "CreateInvoiceDto": {
        "type": "object",
        "properties": {
          "jobId": {
            "type": "string",
            "example": "job-uuid",
            "description": "关联任务ID"
          },
          "amount": {
            "type": "number",
            "example": 5000,
            "description": "总金额（分）"
          },
          "vatAmount": {
            "type": "number",
            "example": 750,
            "description": "VAT 税额（分）"
          },
          "pensionAmount": {
            "type": "number",
            "example": 75,
            "description": "养老金提留额（分）",
            "default": 0
          },
          "companyId": {
            "type": "string",
            "example": "company-uuid"
          }
        },
        "required": [
          "jobId",
          "amount",
          "vatAmount",
          "companyId"
        ]
      },
      "UpdateInvoiceDto": {
        "type": "object",
        "properties": {
          "amount": {
            "type": "number"
          },
          "vatAmount": {
            "type": "number"
          },
          "pensionAmount": {
            "type": "number"
          },
          "status": {
            "type": "string",
            "description": "UNPAID, PAID, VOID"
          }
        }
      }
    }
